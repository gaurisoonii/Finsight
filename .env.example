# CCID Environment Configuration
# Rename this file to .env before running

# Required for AI summaries (optional — graceful fallback mode if absent)
OPENAI_API_KEY=sk-...your-key-here...

# Optional: Use Gemini instead of OpenAI
# GOOGLE_API_KEY=...

# Optional: Use PostgreSQL instead of SQLite for production
# DATABASE_URL=postgresql://user:password@localhost:5432/ccid
